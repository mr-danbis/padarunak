# PostgreSQL — пример переменных (фейковые данные для шаблона)

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=example_password
POSTGRES_DB=wishlist

# Либо одна строка вместо переменных выше:
# DATABASE_URL=postgresql://postgres:example_password@localhost:5432/wishlist
